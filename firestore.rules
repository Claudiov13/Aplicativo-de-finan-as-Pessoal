rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Auth helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
       return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Transaction validation
    function isValidTransaction(data) {
      return data.description is string && data.description.size() <= 200 &&
             data.amount is number &&
             data.type in ['income', 'expense'] &&
             data.date is timestamp &&
             data.userId == request.auth.uid;
    }

    match /transactions/{transactionId} {
      allow create: if isSignedIn() && isValidTransaction(request.resource.data);
      allow update: if isOwner(resource.data.userId) && 
                      isValidTransaction(request.resource.data) &&
                      request.resource.data.userId == resource.data.userId;
      allow delete: if isOwner(resource.data.userId);
      allow list, get: if isOwner(resource.data.userId);
    }
  }
}
